# Copy this file to .env and fill in values before running locally.
# .env is git-ignored and must never be committed.

DATABASE_URL=postgres://chatapp:chatapp@localhost:5432/chatapp

# Tell sqlx::query! to use the .sqlx cache instead of a live DB connection.
# This eliminates IDE errors when Postgres is not running.
SQLX_OFFLINE=true

# Rust log filter — e.g. "info", "debug", "api=debug,sqlx=warn"
RUST_LOG=info