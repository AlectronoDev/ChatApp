  "query": "\n        SELECT u.id AS user_id, u.username, sm.role, sm.joined_at\n        FROM server_members sm\n        JOIN users u ON u.id = sm.user_id\n        WHERE sm.server_id = $1\n        ORDER BY sm.joined_at ASC\n        ",
