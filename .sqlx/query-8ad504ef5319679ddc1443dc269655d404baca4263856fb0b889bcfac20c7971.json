{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT s.id AS session_id, s.user_id, u.username\n            FROM sessions s\n            JOIN users u ON u.id = s.user_id\n            WHERE s.token_hash = $1\n              AND s.revoked_at IS NULL\n              AND s.expires_at > $2\n            ",
