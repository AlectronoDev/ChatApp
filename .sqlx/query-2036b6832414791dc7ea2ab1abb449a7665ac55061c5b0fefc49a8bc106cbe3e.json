  "query": "\n        SELECT s.id AS server_id, s.name, sm.role, s.created_at\n        FROM servers s\n        JOIN server_members sm ON sm.server_id = s.id AND sm.user_id = $1\n        ORDER BY s.created_at DESC\n        ",
